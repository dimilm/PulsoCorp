# Copy this file to `.env` (next to docker-compose.yml) and fill in real
# secrets. Never commit the populated `.env`.

# JWT signing secret. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Symmetric key used to encrypt the configured AI API key (OpenAI, Google
# Gemini, …) in the database.
# MUST be a valid 32-byte URL-safe base64 string. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: rotating this key invalidates the stored API key.
ENCRYPTION_KEY=

# Cookie security flags. Defaults are tuned for an HTTPS deployment:
#   COOKIE_SECURE=true       -> Set-Cookie carries the `Secure` attribute, so
#                               browsers ONLY send the cookie back over HTTPS.
#   COOKIE_SAMESITE=lax      -> Cookies travel on top-level navigations and
#                               same-site requests; blocked on cross-site POSTs.
#
# IMPORTANT: When the app is served over plain HTTP (e.g. a bare-IP deployment
# like http://1.2.3.4:8080 without a TLS terminator in front), you MUST set
#   COOKIE_SECURE=false
# Otherwise the browser silently drops the `ct_access` + `ct_csrf` cookies set
# by /auth/login and every follow-up request fails with `Missing auth cookie`.
# Switch back to `true` (or remove the line to use the default) as soon as
# you put HTTPS in front of the deployment.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Build-time toggle (consumed by docker-compose `build.args`). Set to 1 and
# re-run `docker compose up --build` to bake the optional `playwright` extra
# plus Chromium and its system libraries into the backend image (~500 MB).
# Required for job_sources whose adapter_type is `playwright_api_fetch`,
# `playwright_css_count` or `playwright_text_regex`. Leave at 0 if you only
# use the HTTP-based adapters.
INSTALL_PLAYWRIGHT=0

# Corporate-proxy escape hatch (only relevant when INSTALL_PLAYWRIGHT=1). The
# Chromium download is performed by a Node-based tool that ignores the system
# trust store. In TLS-intercepting environments (Zscaler, Netskope, ...) it
# fails with `UNABLE_TO_GET_ISSUER_CERT_LOCALLY` and the build aborts. Set
# this to 1 to disable Node's TLS verification for that single download step
# (cdn.playwright.dev). Runtime Playwright is unaffected.
# Cleaner alternative: drop your corporate root CA into `docker/corp-ca.crt`,
# add a `COPY` + `ENV NODE_EXTRA_CA_CERTS=/usr/local/share/ca-certificates/corp-ca.crt`
# to `Dockerfile.backend`, and leave this at 0.
PLAYWRIGHT_INSECURE_DOWNLOAD=0
